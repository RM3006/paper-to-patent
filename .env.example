CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
OPENALEX_MAILTO=your.email@example.com
ANTHROPIC_API_KEY=
# PATENTSVIEW_API_KEY=   # optional — supplementary API only

# MotherDuck — the warehouse dbt (prod target) materialises into and the app reads.
MOTHERDUCK_TOKEN=                  # read-write token for the build pipeline (dbt --target prod)
# MOTHERDUCK_DATABASE=paper_to_patent   # MotherDuck database name (default: paper_to_patent)
# DBT_TARGET=prod                       # Dagster dbt build target (default prod→MotherDuck; set dev for local)
# DBT_DUCKDB_PATH=/absolute/path/to/models/dev.duckdb  # local dev.duckdb for the dbt `dev` target / offline runs

# Streamlit UI (set in Streamlit Community Cloud Secrets at deploy time):
#   MOTHERDUCK_TOKEN=<read-only token>   # a separate read-only (read-scaling) token — never the build token
#   MOTHERDUCK_DATABASE=paper_to_patent
