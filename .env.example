CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
OPENALEX_MAILTO=your.email@example.com
ANTHROPIC_API_KEY=
# PATENTSVIEW_API_KEY=   # optional — supplementary API only
# DBT_DUCKDB_PATH=/absolute/path/to/models/dev.duckdb  # required when running gold_export from pipelines/

# Read-only R2 credentials for the Streamlit UI (set in Community Cloud Secrets at deploy time)
# Activate by setting R2_READ_KEY_ID — the app then reads from R2 instead of local dev.duckdb.
# R2_ACCOUNT_ID=                   # Cloudflare account ID (same value as CLOUDFLARE_ACCOUNT_ID)
# R2_READ_KEY_ID=                  # Read-only R2 access key ID (create a separate least-privilege key)
# R2_READ_SECRET=                  # Read-only R2 secret access key
# R2_BUCKET=p2p-lake               # R2 bucket name (default: p2p-lake)
# R2_SNAPSHOT_DATE=2026-06-27      # Gold snapshot date written by gold_export (set at deploy time)
